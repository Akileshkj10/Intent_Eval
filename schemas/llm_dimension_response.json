{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLMDimensionResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dimension_id",
    "score",
    "rationale",
    "evidence_quotes",
    "gaps",
    "improvements"
  ],
  "properties": {
    "dimension_id": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "evidence_quotes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "quote"
        ],
        "properties": {
          "quote": {
            "type": "string",
            "minLength": 1
          },
          "slide_id": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "improvements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
